SPRING_PROFILES_ACTIVE=local

# Local database defaults to in-memory H2. Override these for Postgres-backed runs.
DATABASE_URL=jdbc:h2:mem:bookkeeping;MODE=PostgreSQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
DATABASE_DRIVER=org.h2.Driver

# Auth and cookie settings
BOOKKEEPING_AUTH_TOKEN_SECRET=local-development-token-secret-change-me
BOOKKEEPING_AUTH_TOKEN_TTL=PT8H
BOOKKEEPING_AUTH_REFRESH_TOKEN_TTL=P14D
BOOKKEEPING_AUTH_RESPONSE_TOKENS_ENABLED=true
BOOKKEEPING_AUTH_COOKIES_SECURE=false
BOOKKEEPING_AUTH_COOKIES_SAME_SITE=Lax
BOOKKEEPING_AUTH_PASSWORD_RESET_BASE_URL=

# Frontend/browser integration
BOOKKEEPING_SECURITY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email / notification provider defaults for local development
BOOKKEEPING_NOTIFICATIONS_EMAIL_PROVIDER=logging
BOOKKEEPING_NOTIFICATIONS_PROVIDER_WEBHOOK_SECRET=local-webhook-secret
BOOKKEEPING_NOTIFICATIONS_EMAIL_SENDGRID_BASE_URL=https://api.sendgrid.com
BOOKKEEPING_NOTIFICATIONS_EMAIL_SENDGRID_API_KEY=
BOOKKEEPING_NOTIFICATIONS_EMAIL_SENDGRID_FROM_EMAIL=no-reply@example.test
BOOKKEEPING_NOTIFICATIONS_WEBHOOKS_SENDGRID_PUBLIC_KEY=

# Production notes:
# - Set SPRING_PROFILES_ACTIVE=prod
# - Use a PostgreSQL DATABASE_URL
# - Use a unique BOOKKEEPING_AUTH_TOKEN_SECRET with at least 32 characters
# - Set BOOKKEEPING_AUTH_COOKIES_SECURE=true
# - Set BOOKKEEPING_AUTH_RESPONSE_TOKENS_ENABLED=false
# - Use HTTPS BOOKKEEPING_SECURITY_ALLOWED_ORIGINS and BOOKKEEPING_AUTH_PASSWORD_RESET_BASE_URL
