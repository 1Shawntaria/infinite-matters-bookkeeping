      "item": [
        {
          "name": "Create Owner User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "const ownerEmail = `owner+${timestamp}@acme.test`;",
                  "pm.collectionVariables.set('ownerEmail', ownerEmail);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('ownerUserId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"fullName\": \"{{ownerFullName}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "Create Duplicate Owner User (Expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('duplicate user returns 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('duplicate user response includes clear reason', function () {",
                  "  pm.expect(json.message).to.eql(`A user with email '${pm.collectionVariables.get('ownerEmail')}' already exists`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
