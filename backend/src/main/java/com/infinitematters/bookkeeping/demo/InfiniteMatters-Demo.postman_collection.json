                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "description": "For the balanced demo import, this resolves the `AMZN MKTP` task using `{{amazonMarketplaceTaskId}}`. Run `List Review Tasks` first.",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
