              "host": ["{{baseUrl}}"],
              "path": ["api", "reviews", "tasks", "{{amazonMarketplaceTaskId}}", "resolve"],
              "query": [
                { "key": "organizationId", "value": "{{organizationId}}" }
              ]
            }
          }
