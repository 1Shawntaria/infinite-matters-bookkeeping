    {
      "name": "3. Transactions And Review",
      "item": [
        {
          "name": "Import Demo CSV",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('import succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('import response includes counts', function () {",
                  "  pm.expect(json).to.have.property('postedCount');",
                  "  pm.expect(json).to.have.property('reviewRequiredCount');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "description": "Uses `{{demoCsvPath}}`. Keep the multipart field name exactly `file`; do not add a manual Content-Type header. This is the balanced demo import: you should see some transactions auto-categorize and at least one ambiguous item land in the review queue.",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "{{demoCsvPath}}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/import/csv?organizationId={{organizationId}}&financialAccountId={{financialAccountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "import", "csv"],
              "query": [
                { "key": "organizationId", "value": "{{organizationId}}" },
                { "key": "financialAccountId", "value": "{{financialAccountId}}" }
              ]
            }
          }
        },
        {
          "name": "Import Review-Heavy Demo CSV",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('review-heavy import succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('review-heavy import response includes transaction results', function () {",
                  "  pm.expect(json.transactions).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "description": "Uses `{{reviewHeavyCsvPath}}`. Keep the multipart field name exactly `file`; do not add a manual Content-Type header. This import is intentionally more ambiguous, so it should create a stronger review-queue demo with multiple items needing manual resolution.",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" }
