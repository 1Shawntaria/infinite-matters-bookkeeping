            "url": {
              "raw": "{{baseUrl}}/api/transactions/import/csv?organizationId={{organizationId}}&financialAccountId={{financialAccountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "import", "csv"],
              "query": [
                { "key": "organizationId", "value": "{{organizationId}}" },
                { "key": "financialAccountId", "value": "{{financialAccountId}}" }
              ]
            }
          }
        },
        {
          "name": "List Review Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.unset('reviewTaskId');",
                  "pm.collectionVariables.unset('unknownVendorTaskId');",
                  "pm.collectionVariables.unset('amazonMarketplaceTaskId');",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  pm.collectionVariables.set('reviewTaskId', json[0].taskId);",
                  "  json.forEach(task => {",
                  "    if (task.merchant === 'UNKNOWN VENDOR') {",
                  "      pm.collectionVariables.set('unknownVendorTaskId', task.taskId);",
                  "    }",
                  "    if (task.merchant === 'AMZN MKTP') {",
                  "      pm.collectionVariables.set('amazonMarketplaceTaskId', task.taskId);",
                  "    }",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/reviews/tasks?organizationId={{organizationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reviews", "tasks"],
              "query": [
                { "key": "organizationId", "value": "{{organizationId}}" }
              ]
            }
          }
        },
        {
          "name": "Resolve Review Task As SOFTWARE",
          "request": {
            "description": "Generic resolver using `{{reviewTaskId}}`. Run `List Review Tasks` first so the first open task is captured automatically.",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"finalCategory\": \"SOFTWARE\",\n  \"resolutionComment\": \"Demo override\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reviews/tasks/{{reviewTaskId}}/resolve?organizationId={{organizationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reviews", "tasks", "{{reviewTaskId}}", "resolve"],
              "query": [
                { "key": "organizationId", "value": "{{organizationId}}" }
              ]
            }
          }
        },
        {
          "name": "Resolve UNKNOWN VENDOR As SOFTWARE",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('unknownVendorTaskId')) {",
                  "  throw new Error('Run List Review Tasks first. No UNKNOWN VENDOR review task is currently open.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "description": "For the balanced demo import, this resolves the `UNKNOWN VENDOR` task using `{{unknownVendorTaskId}}`. Run `List Review Tasks` first.",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"finalCategory\": \"SOFTWARE\",\n  \"resolutionComment\": \"Demo override\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reviews/tasks/{{unknownVendorTaskId}}/resolve?organizationId={{organizationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reviews", "tasks", "{{unknownVendorTaskId}}", "resolve"],
              "query": [
                { "key": "organizationId", "value": "{{organizationId}}" }
              ]
            }
          }
        },
        {
          "name": "Resolve AMZN MKTP As OFFICE_SUPPLIES",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('amazonMarketplaceTaskId')) {",
